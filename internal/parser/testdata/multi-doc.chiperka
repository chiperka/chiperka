kind: Service
metadata:
  name: api
spec:
  image: myapp:latest
---
kind: Endpoint
metadata:
  name: api-multi-login
spec:
  service: api
  endpoint:
    method: POST
    url: /auth/login
---
kind: Test
metadata:
  name: multi-login-test
spec:
  endpoint: api-multi-login
  services:
    - ref: api
  execution:
    target: http://api:8080
    request:
      method: POST
      url: /auth/login
  assertions:
    - response:
        statusCode: 200
