kind: Test
metadata:
  name: login-test
  tags:
    - smoke
    - api
spec:
  endpoint: user-login
  services:
    - ref: api
  setup:
    - http:
        target: http://api:8080
        request:
          method: POST
          url: /seed
  execution:
    target: http://api:8080
    request:
      method: POST
      url: /api/login
      headers:
        Content-Type: application/json
      body: '{"email": "test@example.com"}'
  assertions:
    - response:
        statusCode: 200
  teardown:
    - http:
        target: http://api:8080
        request:
          method: POST
          url: /cleanup
